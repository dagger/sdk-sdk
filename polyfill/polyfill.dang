"""
Polyfill for missing or broken engine calls used by SDK development.
"""
type Polyfill {
  """
  Project a core workspace to a polyfill workspace.
  """
  pub workspace(ws: Workspace!): PolyfillWorkspace! {
    PolyfillWorkspace(
      wsID: toJSON(ws.id),
      cwd: PolyfillWorkspaceCwd().path(ws),
    )
  }
}
